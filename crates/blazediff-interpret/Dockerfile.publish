FROM rust:latest

WORKDIR /app

RUN apt-get update && apt-get install -y \
    cmake \
    nasm \
    zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

COPY Cargo.toml Cargo.lock ./
COPY blazediff/ blazediff/
COPY blazediff-interpret/ blazediff-interpret/

WORKDIR /app/blazediff-interpret

# Token passed via file mount at runtime as env var (--token is deprecated)
CMD ["sh", "-c", "CARGO_REGISTRY_TOKEN=$(cat /run/secrets/crates_token) cargo publish"]
