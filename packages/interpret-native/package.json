{
	"name": "@blazediff/interpret-native",
	"version": "0.1.0",
	"description": "Native Rust bindings for blazediff-interpret - structured image diff analysis",
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsup",
		"clean": "rm -rf dist"
	},
	"optionalDependencies": {
		"@blazediff/interpret-native-darwin-arm64": "0.1.0",
		"@blazediff/interpret-native-darwin-x64": "0.1.0",
		"@blazediff/interpret-native-linux-arm64": "0.1.0",
		"@blazediff/interpret-native-linux-x64": "0.1.0",
		"@blazediff/interpret-native-win32-arm64": "0.1.0",
		"@blazediff/interpret-native-win32-x64": "0.1.0"
	},
	"keywords": [
		"image",
		"diff",
		"analysis",
		"visual-regression",
		"interpret",
		"native",
		"rust"
	],
	"author": "Teimur Gasanov <me@teimurjan.dev> (https://github.com/teimurjan)",
	"repository": "https://github.com/teimurjan/blazediff",
	"homepage": "https://blazediff.dev",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^24.3.0",
		"tsup": "8.5.0",
		"typescript": "5.9.2"
	}
}
