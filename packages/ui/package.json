{
	"name": "@blazediff/ui",
	"version": "1.6.6",
	"description": "Headless engine and framework-agnostic renderer for image-diff UIs",
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./engine": {
			"types": "./dist/engine.d.ts",
			"import": "./dist/engine.mjs",
			"require": "./dist/engine.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"keywords": [
		"image",
		"comparison",
		"diff",
		"headless",
		"ui",
		"visual-testing"
	],
	"author": "Teimur Gasanov <me@teimurjan.dev> (https://github.com/teimurjan)",
	"repository": "https://github.com/teimurjan/blazediff",
	"homepage": "https://blazediff.dev",
	"license": "MIT",
	"dependencies": {
		"@blazediff/core": "workspace:*"
	},
	"devDependencies": {
		"@storybook/addon-links": "^9.1.8",
		"@storybook/html": "9.1.8",
		"@storybook/html-vite": "9.1.8",
		"@tailwindcss/vite": "^4.1.13",
		"@types/node": "^24.3.0",
		"storybook": "^9.1.8",
		"tailwindcss": "^4.1.13",
		"tsup": "8.5.0",
		"typescript": "5.9.2",
		"vite": "^7.1.7"
	}
}
