{
	"name": "@blazediff/agent",
	"version": "0.1.1",
	"description": "Agentic visual regression for BlazeDiff. Auto-discovers routes, captures deterministic screenshots, runs CI checks.",
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"bin": {
		"blazediff-agent": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"SKILL.md",
		"JUDGING.md",
		"MASKING.md"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"prebuild": "node -e \"const {readdirSync,copyFileSync}=require('node:fs');for(const f of readdirSync('../../skill/blazediff'))if(f.endsWith('.md')&&f!=='INSTALL.md')copyFileSync('../../skill/blazediff/'+f,f)\"",
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist SKILL.md JUDGING.md MASKING.md",
		"test": "vitest run --passWithNoTests"
	},
	"keywords": [
		"visual-regression",
		"screenshot",
		"diff",
		"agent",
		"playwright",
		"ci",
		"blazediff"
	],
	"author": "Teimur Gasanov <me@teimurjan.dev> (https://github.com/teimurjan)",
	"repository": "https://github.com/teimurjan/blazediff",
	"homepage": "https://blazediff.dev",
	"license": "MIT",
	"dependencies": {
		"@blazediff/core-native": "workspace:*",
		"@langchain/core": "^1.1.44",
		"@langchain/langgraph": "^1.3.0",
		"@langchain/langgraph-checkpoint": "^1.0.2",
		"commander": "^13.1.0",
		"playwright": "^1.50.0",
		"sharp": "^0.34.0",
		"tree-kill": "^1.2.2",
		"zod": "^3.25.32"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"tsup": "8.5.0",
		"typescript": "5.9.2",
		"vitest": "^3.2.4"
	}
}
